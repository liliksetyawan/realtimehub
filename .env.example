# Copy to .env for local dev. main.go auto-loads it via godotenv.

# --- HTTP / WebSocket ---
HTTP_ADDR=:8090

# --- JWT ---
# Anything random for dev. Use a 256-bit secret in production.
JWT_SECRET=change-me-in-production-please
JWT_TTL=24h

# --- Postgres ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=realtimehub
POSTGRES_PASSWORD=realtimehub
POSTGRES_DB=realtimehub

# --- Redis ---
REDIS_ADDR=localhost:6380

# --- Tracing ---
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Hub tuning ---
HUB_SHARDS=16
WRITE_BUFFER=64
PING_INTERVAL=25s
PONG_TIMEOUT=60s

# --- CORS for the React SPA ---
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
